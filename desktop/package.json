{
  "name": "jewello-soft",
  "version": "3.0.1",
  "description": "JewelloSoft",
  "main": "main.js",
  "author": "JewelloSoft",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "start": "electron .",
    "prebuild": "node check_backend.js",
    "build": "electron-builder --win",
    "build:publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.jewellosoft.desktop",
    "productName": "JewelloSoft",
    "executableName": "JewelloSoft",
    "copyright": "Copyright © 2026 Sudeepta Bhakat",
    "compression": "maximum",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "forceCodeSigning": false,
      "signtoolOptions": {
        "publisherName": null
      }
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JewelloSoft",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "../backend/dist/backend",
        "to": "backend"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "SudeeptoBhakat",
      "repo": "Jewellosoft",
      "releaseType": "release"
    },
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "main.js",
      "preload.js",
      "crash.html",
      "splash.html",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "stat-mode": "^1.0.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
